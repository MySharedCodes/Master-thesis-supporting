Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Transient", " ", "Motion", " ", "Simulation", " ", "of", " ", "a", " ", 
    "1", "D", " ", "Atomic", " ", "Chain", " ", "in", " ", "2", "D", " ", 
    "Space", " ", "with", " ", "Linear", " ", "Restoring", " ", "Force"}], 
   "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Parameter", " ", "Settings"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"nAtoms", "=", "10"}], ";", 
    RowBox[{"(*", 
     RowBox[{"Number", " ", "of", " ", "atoms"}], "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{"m", "=", "1"}], ";", 
    RowBox[{"(*", 
     RowBox[{"Mass", " ", "of", " ", "each", " ", "atom"}], "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{"a", "=", "1"}], ";", 
    RowBox[{"(*", 
     RowBox[{"Lattice", " ", "constant"}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{"k1x", "=", "1"}], ";", 
    RowBox[{"(*", 
     RowBox[{"Spring", " ", "constant", " ", "between", " ", "atoms"}], 
     "*)"}], "\[IndentingNewLine]", 
    RowBox[{"k1y", "=", "1"}], ";", 
    RowBox[{"(*", 
     RowBox[{"Spring", " ", "constant", " ", "between", " ", "atoms"}], 
     "*)"}], "\[IndentingNewLine]", 
    RowBox[{"k2", "=", "0"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"k3", "=", "2"}], ";", 
    RowBox[{"(*", 
     RowBox[{
     "Elastic", " ", "constant", " ", "of", " ", "the", " ", "barrier", " ", 
      RowBox[{"(", 
       RowBox[{"restoring", " ", "force", " ", "strength"}], ")"}]}], "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{"\[Gamma]", "=", "0"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"y0", "=", "5"}], ";"}], 
   RowBox[{"(*", 
    RowBox[{"Barrier", " ", "equilibrium", " ", "position"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"tMax", "=", "100"}], ";", 
    RowBox[{"(*", 
     RowBox[{"Total", " ", "simulation", " ", "time"}], "*)"}], "\n", 
    RowBox[{
     SubscriptBox["A", "x"], "=", "0.1"}], ";", 
    RowBox[{
     SubscriptBox["A", "y"], "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Omega]", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Initial", " ", "conditions"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"initialVelocities", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0.0", ",", "0.0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "nAtoms"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"xEq", "[", "n_", "]"}], ":=", 
     RowBox[{"n", "*", "a"}]}], ";", 
    RowBox[{
     RowBox[{"yEq", "[", "n_", "]"}], ":=", "0"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Define", " ", "force"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"barrierForce", "[", "y_", "]"}], ":=", 
     RowBox[{"Piecewise", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "k3"}], "*", 
           RowBox[{"(", 
            RowBox[{"y", "-", "y0"}], ")"}]}], ",", 
          RowBox[{"y", ">", "y0"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"k2", "*", "y"}], ",", 
          RowBox[{
           RowBox[{"-", "y0"}], "<", "y", "<", "y0"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "k3"}], "*", 
           RowBox[{"(", 
            RowBox[{"y", "+", "y0"}], ")"}]}], ",", 
          RowBox[{"y", "<", 
           RowBox[{"-", "y0"}]}]}], "}"}]}], "}"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"xForce", "[", 
      RowBox[{"n_", ",", "t_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "}"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"n", "\[Equal]", "1"}], ",", "0", ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"n", "\[Equal]", "nAtoms"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "k1x"}], 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"x", "[", "nAtoms", "]"}], "[", "t", "]"}], "-", 
               RowBox[{
                RowBox[{"x", "[", 
                 RowBox[{"nAtoms", "-", "1"}], "]"}], "[", "t", "]"}], "-", 
               "a"}], ")"}]}], "-", 
            RowBox[{"\[Gamma]", " ", 
             RowBox[{
              RowBox[{"vx", "[", "n", "]"}], "[", "t", "]"}]}]}], ",", 
           RowBox[{
            RowBox[{"k1x", 
             RowBox[{"(", 
