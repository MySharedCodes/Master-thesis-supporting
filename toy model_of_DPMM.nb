               RowBox[{
                RowBox[{"x", "[", 
                 RowBox[{"n", "+", "1"}], "]"}], "[", "t", "]"}], "-", 
               RowBox[{
                RowBox[{"x", "[", "n", "]"}], "[", "t", "]"}], "-", "a"}], 
              ")"}]}], "-", 
            RowBox[{"k1x", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"x", "[", "n", "]"}], "[", "t", "]"}], "-", 
               RowBox[{
                RowBox[{"x", "[", 
                 RowBox[{"n", "-", "1"}], "]"}], "[", "t", "]"}], "-", "a"}], 
              ")"}]}], "-", 
            RowBox[{"\[Gamma]", " ", 
             RowBox[{
              RowBox[{"vx", "[", "n", "]"}], "[", "t", "]"}]}]}]}], "]"}]}], 
        "]"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"yForce", "[", 
      RowBox[{"n_", ",", "t_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "}"}], ",", 
