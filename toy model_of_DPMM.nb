Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", 
   RowBox[{
   "Transient", " ", "Motion", " ", "Simulation", " ", "of", " ", "a", " ", 
    "1", "D", " ", "Atomic", " ", "Chain", " ", "in", " ", "2", "D", " ", 
    "Space", " ", "with", " ", "Linear", " ", "Restoring", " ", "Force"}], 
   "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"ClearAll", "[", "\"\<Global`*\>\"", "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Parameter", " ", "Settings"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"nAtoms", "=", "10"}], ";", 
    RowBox[{"(*", 
     RowBox[{"Number", " ", "of", " ", "atoms"}], "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{"m", "=", "1"}], ";", 
    RowBox[{"(*", 
     RowBox[{"Mass", " ", "of", " ", "each", " ", "atom"}], "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{"a", "=", "1"}], ";", 
    RowBox[{"(*", 
     RowBox[{"Lattice", " ", "constant"}], "*)"}], "\[IndentingNewLine]", 
    RowBox[{"k1x", "=", "1"}], ";", 
    RowBox[{"(*", 
     RowBox[{"Spring", " ", "constant", " ", "between", " ", "atoms"}], 
     "*)"}], "\[IndentingNewLine]", 
    RowBox[{"k1y", "=", "1"}], ";", 
    RowBox[{"(*", 
     RowBox[{"Spring", " ", "constant", " ", "between", " ", "atoms"}], 
     "*)"}], "\[IndentingNewLine]", 
    RowBox[{"k2", "=", "0"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"k3", "=", "2"}], ";", 
    RowBox[{"(*", 
     RowBox[{
     "Elastic", " ", "constant", " ", "of", " ", "the", " ", "barrier", " ", 
      RowBox[{"(", 
       RowBox[{"restoring", " ", "force", " ", "strength"}], ")"}]}], "*)"}], 
    "\[IndentingNewLine]", 
    RowBox[{"\[Gamma]", "=", "0"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"y0", "=", "1"}], ";"}], 
   RowBox[{"(*", 
    RowBox[{"Barrier", " ", "equilibrium", " ", "position"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"tMax", "=", "500"}], ";", 
    RowBox[{"(*", 
     RowBox[{"Total", " ", "simulation", " ", "time"}], "*)"}], "\n", 
    RowBox[{
     SubscriptBox["A", "x"], "=", "0.1"}], ";", 
    RowBox[{
     SubscriptBox["A", "y"], "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[Omega]", "=", "1"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Initial", " ", "conditions"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"initialVelocities", "=", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"0.0", ",", "0.0"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"n", ",", "nAtoms"}], "}"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"xEq", "[", "n_", "]"}], ":=", 
     RowBox[{"n", "*", "a"}]}], ";", 
    RowBox[{
     RowBox[{"yEq", "[", "n_", "]"}], ":=", "0"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Define", " ", "force"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"barrierForce", "[", "y_", "]"}], ":=", 
     RowBox[{"Piecewise", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "k3"}], "*", 
           RowBox[{"(", 
            RowBox[{"y", "-", "y0"}], ")"}]}], ",", 
          RowBox[{"y", ">", "y0"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"k2", "*", "y"}], ",", 
          RowBox[{
           RowBox[{"-", "y0"}], "<", "y", "<", "y0"}]}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{"-", "k3"}], "*", 
           RowBox[{"(", 
            RowBox[{"y", "+", "y0"}], ")"}]}], ",", 
          RowBox[{"y", "<", 
           RowBox[{"-", "y0"}]}]}], "}"}]}], "}"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"xForce", "[", 
      RowBox[{"n_", ",", "t_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "}"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"n", "\[Equal]", "1"}], ",", "0", ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"n", "\[Equal]", "nAtoms"}], ",", 
           RowBox[{
            RowBox[{
             RowBox[{"-", "k1x"}], 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"x", "[", "nAtoms", "]"}], "[", "t", "]"}], "-", 
               RowBox[{
                RowBox[{"x", "[", 
                 RowBox[{"nAtoms", "-", "1"}], "]"}], "[", "t", "]"}], "-", 
               "a"}], ")"}]}], "-", 
            RowBox[{"\[Gamma]", " ", 
             RowBox[{
              RowBox[{"vx", "[", "n", "]"}], "[", "t", "]"}]}]}], ",", 
           RowBox[{
            RowBox[{"k1x", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"x", "[", 
                 RowBox[{"n", "+", "1"}], "]"}], "[", "t", "]"}], "-", 
               RowBox[{
                RowBox[{"x", "[", "n", "]"}], "[", "t", "]"}], "-", "a"}], 
              ")"}]}], "-", 
            RowBox[{"k1x", 
             RowBox[{"(", 
              RowBox[{
               RowBox[{
                RowBox[{"x", "[", "n", "]"}], "[", "t", "]"}], "-", 
               RowBox[{
                RowBox[{"x", "[", 
                 RowBox[{"n", "-", "1"}], "]"}], "[", "t", "]"}], "-", "a"}], 
              ")"}]}], "-", 
            RowBox[{"\[Gamma]", " ", 
             RowBox[{
              RowBox[{"vx", "[", "n", "]"}], "[", "t", "]"}]}]}]}], "]"}]}], 
        "]"}]}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"yForce", "[", 
      RowBox[{"n_", ",", "t_"}], "]"}], ":=", 
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", "}"}], ",", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"n", "\[Equal]", "1"}], ",", "0", ",", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"n", "\[Equal]", "nAtoms"}], ",", 
           RowBox[{"neighborForce", "=", 
            RowBox[{
             RowBox[{
              RowBox[{"-", "k1y"}], 
              RowBox[{"(", 
               RowBox[{
                RowBox[{
                 RowBox[{"y", "[", "nAtoms", "]"}], "[", "t", "]"}], "-", 
                RowBox[{
                 RowBox[{"y", "[", 
                  RowBox[{"nAtoms", "-", "1"}], "]"}], "[", "t", "]"}]}], 
               ")"}]}], "+", 
             RowBox[{"barrierForce", "[", 
              RowBox[{
               RowBox[{"y", "[", "nAtoms", "]"}], "[", "t", "]"}], "]"}], "-", 
             RowBox[{"\[Gamma]", " ", 
              RowBox[{
               RowBox[{"vy", "[", "n", "]"}], "[", "t", "]"}]}]}]}], ",", 
           RowBox[{"neighborForce", "=", 
            RowBox[{
             RowBox[{"k1y", 
              RowBox[{"(", 
               RowBox[{
                RowBox[{
                 RowBox[{"y", "[", 
                  RowBox[{"n", "+", "1"}], "]"}], "[", "t", "]"}], "-", 
                RowBox[{"2", "*", 
                 RowBox[{
                  RowBox[{"y", "[", "n", "]"}], "[", "t", "]"}]}], "+", 
                RowBox[{
                 RowBox[{"y", "[", 
                  RowBox[{"n", "-", "1"}], "]"}], "[", "t", "]"}]}], ")"}]}], 
             "+", 
             RowBox[{"barrierForce", "[", 
              RowBox[{
               RowBox[{"y", "[", "n", "]"}], "[", "t", "]"}], "]"}], "-", 
             RowBox[{"\[Gamma]", " ", 
              RowBox[{
               RowBox[{"vy", "[", "n", "]"}], "[", "t", "]"}]}]}]}]}], 
          "]"}]}], "]"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"eqs", "=", 
     RowBox[{"Flatten", "@", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"x", "[", "1", "]"}], "[", "t", "]"}], "\[Equal]", 
           RowBox[{
            RowBox[{"xEq", "[", "1", "]"}], "+", 
            RowBox[{
             SubscriptBox["A", "x"], " ", 
             RowBox[{"Sin", "[", 
              RowBox[{"\[Omega]", " ", "t"}], "]"}]}]}]}], ",", 
          RowBox[{
           RowBox[{
            RowBox[{"y", "[", "1", "]"}], "[", "t", "]"}], "\[Equal]", 
           RowBox[{
            RowBox[{"yEq", "[", "n", "]"}], "+", 
            RowBox[{
             SubscriptBox["A", "y"], " ", 
             RowBox[{"Sin", "[", 
              RowBox[{"\[Omega]", " ", "t"}], "]"}]}]}]}]}], "}"}], ",", 
        RowBox[{"Flatten", "[", 
         RowBox[{"Table", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"x", "[", "n", "]"}], "'"}], "[", "t", "]"}], 
              "\[Equal]", 
              RowBox[{
               RowBox[{"vx", "[", "n", "]"}], "[", "t", "]"}]}], ",", 
             RowBox[{
              RowBox[{
               RowBox[{
                RowBox[{"y", "[", "n", "]"}], "'"}], "[", "t", "]"}], 
              "\[Equal]", 
              RowBox[{
               RowBox[{"vy", "[", "n", "]"}], "[", "t", "]"}]}], ",", 
             RowBox[{
              RowBox[{"m", "*", 
               RowBox[{
                RowBox[{
                 RowBox[{"vx", "[", "n", "]"}], "'"}], "[", "t", "]"}]}], 
              "\[Equal]", 
              RowBox[{"xForce", "[", 
               RowBox[{"n", ",", "t"}], "]"}]}], ",", 
             RowBox[{
              RowBox[{"m", "*", 
               RowBox[{
                RowBox[{
                 RowBox[{"vy", "[", "n", "]"}], "'"}], "[", "t", "]"}]}], 
              "\[Equal]", 
              RowBox[{"yForce", "[", 
               RowBox[{"n", ",", "t"}], "]"}]}]}], "}"}], ",", 
           RowBox[{"{", 
            RowBox[{"n", ",", "2", ",", "nAtoms"}], "}"}]}], "]"}], "]"}]}], 
       "}"}]}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Initial", " ", "Conditions"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"ics", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"x", "[", "n", "]"}], "[", "0", "]"}], "\[Equal]", 
           RowBox[{"xEq", "[", "n", "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "nAtoms"}], "}"}]}], "]"}], ",", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"y", "[", "n", "]"}], "[", "0", "]"}], "\[Equal]", 
           RowBox[{"yEq", "[", "n", "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "nAtoms"}], "}"}]}], "]"}], ",", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"vx", "[", "n", "]"}], "[", "0", "]"}], "\[Equal]", 
           RowBox[{"initialVelocities", "[", 
            RowBox[{"[", 
             RowBox[{"n", ",", "1"}], "]"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "2", ",", "nAtoms"}], "}"}]}], "]"}], ",", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{
           RowBox[{
            RowBox[{"vy", "[", "n", "]"}], "[", "0", "]"}], "\[Equal]", 
           RowBox[{"initialVelocities", "[", 
            RowBox[{"[", 
             RowBox[{"n", ",", "2"}], "]"}], "]"}]}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "2", ",", "nAtoms"}], "}"}]}], "]"}]}], "}"}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{"Variable", " ", "List"}], "*)"}], "\n", 
   RowBox[{
    RowBox[{"vars", "=", 
     RowBox[{"Flatten", "[", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"x", "[", "1", "]"}], ",", 
        RowBox[{"y", "[", "1", "]"}], ",", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"x", "[", "n", "]"}], ",", 
            RowBox[{"y", "[", "n", "]"}], ",", 
            RowBox[{"vx", "[", "n", "]"}], ",", 
            RowBox[{"vy", "[", "n", "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{"n", ",", "2", ",", "nAtoms"}], "}"}]}], "]"}]}], "}"}], 
      "]"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", "solver", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"sol", "=", 
     RowBox[{"NDSolve", "[", 
      RowBox[{
       RowBox[{"Join", "[", 
        RowBox[{"eqs", ",", "ics"}], "]"}], ",", "vars", ",", 
       RowBox[{"{", 
        RowBox[{"t", ",", "0", ",", "tMax"}], "}"}], ",", 
       RowBox[{"MaxStepSize", "\[Rule]", 
        RowBox[{"1", "/", "k3"}]}], ",", 
       RowBox[{"Method", "\[Rule]", 
        RowBox[{"{", "\"\<Automatic\>\"", "}"}]}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"Extract", " ", "Solution", " ", "Functions"}], "*)"}], 
   "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"xSol", "[", "n_", "]"}], "[", "t_", "]"}], ":=", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"x", "[", "n", "]"}], "[", "t", "]"}], "/.", 
        RowBox[{"sol", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ",", "16"}], "]"}]}], ";"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"ySol", "[", "n_", "]"}], "[", "t_", "]"}], ":=", 
     RowBox[{"SetPrecision", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"y", "[", "n", "]"}], "[", "t", "]"}], "/.", 
        RowBox[{"sol", "[", 
         RowBox[{"[", "1", "]"}], "]"}]}], ",", "16"}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"Manipulate", "[", 
     RowBox[{
      RowBox[{"Graphics", "[", 
       RowBox[{
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"Gray", ",", "Dashed", ",", 
            RowBox[{"Line", "[", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"0", ",", "y0"}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"nAtoms", "*", "a"}], ",", "y0"}], "}"}]}], "}"}], 
             "]"}], ",", 
            RowBox[{"Line", "[", 
             RowBox[{"{", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{"0", ",", 
                 RowBox[{"-", "y0"}]}], "}"}], ",", 
               RowBox[{"{", 
                RowBox[{
                 RowBox[{"nAtoms", "*", "a"}], ",", 
                 RowBox[{"-", "y0"}]}], "}"}]}], "}"}], "]"}]}], "}"}], ",", 
          RowBox[{"(*", 
           RowBox[{"Barrier", " ", "equilibrium", " ", "position"}], "*)"}], 
          RowBox[{"{", 
           RowBox[{"LightBlue", ",", 
            RowBox[{"Opacity", "[", "0.2", "]"}], ",", 
            RowBox[{"Rectangle", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "0.5"}], ",", "y0"}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{
                 RowBox[{"nAtoms", "*", "a"}], "+", "0.5"}], ",", 
                RowBox[{"y0", "+", "2"}]}], "}"}]}], "]"}], ",", 
            RowBox[{"Rectangle", "[", 
             RowBox[{
              RowBox[{"{", 
               RowBox[{
                RowBox[{"-", "0.5"}], ",", 
                RowBox[{"-", "y0"}]}], "}"}], ",", 
              RowBox[{"{", 
               RowBox[{
                RowBox[{
                 RowBox[{"nAtoms", "*", "a"}], "+", "0.5"}], ",", 
                RowBox[{
                 RowBox[{"-", "y0"}], "-", "2"}]}], "}"}]}], "]"}]}], "}"}], 
          ",", 
          RowBox[{"(*", 
           RowBox[{"Barrier", " ", "region"}], "*)"}], 
          RowBox[{"{", 
           RowBox[{"Red", ",", 
            RowBox[{"PointSize", "[", "0.02", "]"}], ",", 
            RowBox[{"Point", "[", 
             RowBox[{"Table", "[", 
              RowBox[{
               RowBox[{"{", 
                RowBox[{
                 RowBox[{
                  RowBox[{"xSol", "[", "n", "]"}], "[", "t", "]"}], ",", 
                 RowBox[{
                  RowBox[{"ySol", "[", "n", "]"}], "[", "t", "]"}]}], "}"}], 
               ",", 
               RowBox[{"{", 
                RowBox[{"n", ",", "nAtoms"}], "}"}]}], "]"}], "]"}]}], "}"}], 
          ",", 
          RowBox[{"(*", 
           RowBox[{"Atom", " ", "positions"}], "*)"}], 
          RowBox[{"{", 
           RowBox[{"Blue", ",", 
